# This is Git's per-user configuration file.
[user]
	name = Quinn McCaffrey
	email = quinn@versaliminal.org
#	signingkey = 

[init]
	defaultBranch = main
	templateDir = ~/.git-templates

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[alias]
    cprev = !git rev-parse --short @ | tr -d '\n' | pbcopy && echo "Copied $(pbpaste)"
	changes = log --oneline main..$(git branch --show-current)
	last-msg = log -1 --pretty=%B

	freebase = !git fetch && git rebase --no-verify -i origin/main

	placeholder = commit --no-verify --allow-empty -S -m "" && push -u origin $(git branch --show-current)
	feat = checkout -b "$1" && placeholder
	base = merge-base main $(git branch --show-current)
	soft-rebase = reset --soft $(base)
	fixup = commit --no-verify -a --fixup=$(base)
	append = !git fixup && git rebase --no-verify -i --autosquash origin/main
	reword = commit --no-verify --amend --allow-empty
	squash = commit --amend --allow-empty --no-verify -S -m "$(last-msg)"
	unstage = restore --staged "$1"

	sign = commit --amend --no-edit -S --allow-empty
	pub = push -f
	spub = !git sign && git pub

	discard = !git fetch && reset --hard origin/$(git branch --show-current)
	main = !git fetch && checkout main && reset --hard origin/main
